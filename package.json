{
  "name": "ai-platform",
  "private": true,
  "scripts": {
    "frontend": "npm --prefix frontend run dev",
    "backend": "uvicorn app.main:app --app-dir backend --reload --host 0.0.0.0 --port 8000",
    "dev": "concurrently -n FRONTEND,BACKEND -c blue,green \"npm run frontend\" \"npm run backend\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}